<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="SunsetGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7EB9" Offset="0.0" />
        <GradientStop Color="#FFD166" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="DarkCarbonBackgroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="DarkCarbonComponentBrush" Color="#222222"/>
    <SolidColorBrush x:Key="TextHighContrastBrush" Color="#FFFFFF"/>

    <GridLength x:Key="TouchTargetMinimumDimension">40</GridLength>
    <CornerRadius x:Key="FloatingShellCornerRadius">16</CornerRadius>
</ResourceDictionary>
