<UserControl
    x:Class="Windows12.UI_Components.StartMenu.StartMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource SurfaceBackgroundBrush}" 
            CornerRadius="16" 
            Width="600" Height="700" 
            BorderThickness="1" 
            BorderBrush="{ThemeResource TaskbarBorderBrush}"
            Padding="24">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" PlaceholderText="Search local system and Dev Workspaces..." Height="48" CornerRadius="8"/>

            <GridView Grid.Row="1" Margin="0,24,0,0">
                <GridViewItem>
                    <StackPanel Spacing="8" Width="80" Height="80" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE756;" FontSize="32" Foreground="{ThemeResource PrimaryIconColor}"/>
                        <TextBlock Text="Terminal" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </GridViewItem>
                <GridViewItem>
                    <StackPanel Spacing="8" Width="80" Height="80" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE943;" FontSize="32" Foreground="{ThemeResource PrimaryIconColor}"/>
                        <TextBlock Text="Profiler" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </GridViewItem>
                </GridView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                <Button Content="Sleep" Background="Transparent"/>
                <Button Content="Restart" Background="Transparent"/>
                <Button Content="Shutdown" Background="{ThemeResource AccentColorBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
