<UserControl
    x:Class="Windows12.UI_Components.Widgets.WidgetCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas x:Name="DesktopWidgetSurface" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        
        <Border Canvas.Left="1500" Canvas.Top="50" Width="300" Height="150" 
                Background="{ThemeResource TaskbarBackgroundBrush}" 
                CornerRadius="12" Padding="16">
            <StackPanel>
                <TextBlock Text="NPU Telemetry" Foreground="{ThemeResource PrimaryIconColor}" FontWeight="Bold"/>
                <TextBlock Text="Status: Local Inference Active" Foreground="LightGreen" Margin="0,8,0,0"/>
                <TextBlock Text="Load: 12 TOPS" Foreground="{ThemeResource PrimaryIconColor}"/>
            </StackPanel>
        </Border>
        
    </Canvas>
</UserControl>
