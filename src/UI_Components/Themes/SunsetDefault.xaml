<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="SunsetDesktopBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7EB9" Offset="0.0"/>
        <GradientStop Color="#FFD166" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TaskbarBackgroundBrush" Color="#B3FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="TaskbarBorderBrush" Color="#4DFFFFFF"/>
    
    <SolidColorBrush x:Key="PrimaryIconColor" Color="#FF111111"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#33000000"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="#FF7EB9"/>

</ResourceDictionary>
