<Window
    x:Class="Windows12.UI_Components.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Windows12.UI_Components.Views"
    Title="Windows 12 Presentation Shell">

    <Canvas x:Name="RootDesktopCanvas" Background="{StaticResource SunsetGradientBrush}">
        <views:WorkspaceView Canvas.Left="40" Canvas.Top="40" Width="400" Height="600"/>

        <views:TaskbarView Canvas.Left="460" Canvas.Bottom="24" Width="1000" Height="72"/>
    </Canvas>
</Window>
