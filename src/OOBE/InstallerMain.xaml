<Window
    x:Class="Windows12.OOBE.InstallerMain"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Project Rebirth Setup">

    <Grid Background="{StaticResource SunsetGradientBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            
            <TextBlock Text="Just Like Home." 
                       FontSize="64" 
                       FontWeight="Bold" 
                       Foreground="#111111" 
                       HorizontalAlignment="Center"/>
            
            <TextBlock Text="No bloat. No forced telemetry. Absolute system control." 
                       FontSize="20" 
                       Foreground="#333333" 
                       HorizontalAlignment="Center"/>

            <Border Background="#CCFFFFFF" CornerRadius="12" Padding="32" Margin="0,40,0,0">
                <StackPanel Spacing="16">
                    <TextBlock Text="Establish your local environment:" FontWeight="SemiBold"/>
                    
                    <TextBox x:Name="LocalAccountName" PlaceholderText="Local Admin Username" Width="300"/>
                    <PasswordBox x:Name="LocalAccountPassword" PlaceholderText="Secure Password" Width="300"/>
                    
                    <Button Content="Configure Default Browser" 
                            Width="300" 
                            Height="40" 
                            Margin="0,16,0,0"
                            Click="OnBrowserSelectClicked"/>
                            
                    <Button Content="Initialize CorePC Architecture" 
                            Background="#FF7EB9" 
                            Foreground="White"
                            Width="300" 
                            Height="48" 
                            Margin="0,8,0,0"
                            Click="OnInitializeSystemClicked"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
